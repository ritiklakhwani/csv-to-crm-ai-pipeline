# dependencies + build output (rebuilt inside the image)
node_modules
**/node_modules
**/dist
**/.next
**/coverage
**/*.tsbuildinfo

# secrets — env is injected at runtime, never baked into a layer
**/.env
**/.env.local
!**/.env.example

# local caches
.llm-cache
.pnpm-store

# vcs / editor / os
.git
.github
.vscode
.DS_Store
**/.DS_Store

# local planning material and tooling — not part of the deliverable
reference-screenshots
reference-readmes
.agents
skills-lock.json
logos

# tests are run in CI/locally, not inside the production image build
backend/tests
frontend/tests
