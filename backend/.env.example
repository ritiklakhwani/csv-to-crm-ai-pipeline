# Copy to backend/.env and fill in. Never commit the real file.

NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Comma-separated. Locked down to the deployed frontend origin in production.
ALLOWED_ORIGIN=http://localhost:3000

# --- LLM -------------------------------------------------------------------------------------
# Adding a new provider means adding one file and one value here. Nothing in services/extraction
# imports a vendor SDK.
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Phase 1 — schema inference. One call per file, so favour accuracy.
LLM_MODEL_INFERENCE=gpt-4.1-mini-2025-04-14
# Phase 2 — batch row extraction. N calls per file, so favour cost and latency.
LLM_MODEL_EXTRACTION=gpt-4.1-mini-2025-04-14

# Memoise LLM responses to .llm-cache/ keyed by prompt hash. Lets you iterate on the frontend all
# day without spending a cent. Must stay false in production.
LLM_CACHE=false

# Total attempts per batch, including the first.
LLM_MAX_RETRIES=3
# Dropped automatically for models that reject sampling parameters.
LLM_TEMPERATURE=0

# --- Pipeline tuning -------------------------------------------------------------------------
BATCH_SIZE=25
MAX_CONCURRENCY=4

# --- Deployed-endpoint guards ----------------------------------------------------------------
MAX_ROWS=2000
MAX_FILE_SIZE_MB=5
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
